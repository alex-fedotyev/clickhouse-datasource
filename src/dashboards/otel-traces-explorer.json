{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["clickhouse", "otel"],
      "title": "ClickHouse OTEL Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "id": 10,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  ServiceName,\n  count() / $__interval_s AS rps\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time, ServiceName\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "id": 11,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  countIf(StatusCode = 'STATUS_CODE_ERROR') / count() AS error_rate\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ns"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "solid" } }] },
          { "matcher": { "id": "byName", "options": "p90" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dot" } }, { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "id": 12,
      "title": "Duration Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  quantile(0.5)(Duration) AS p50,\n  quantile(0.9)(Duration) AS p90,\n  quantile(0.99)(Duration) AS p99\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "links": [
            {
              "title": "View trace",
              "url": "/explore?left={\"datasource\":\"${datasource}\",\"queries\":[{\"editorType\":\"sql\",\"rawSql\":\"SELECT * FROM $__database.otel_traces WHERE TraceId = '${__data.fields.TraceId}' ORDER BY Timestamp\",\"refId\":\"A\",\"format\":3}],\"range\":{\"from\":\"${__data.fields[\\\"Start Time\\\"]}\",\"to\":\"now\"}}"
            }
          ]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Duration" }, "properties": [{ "id": "unit", "value": "ns" }] },
          { "matcher": { "id": "byName", "options": "SpanCount" }, "properties": [{ "id": "displayName", "value": "Spans" }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 5 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Start Time" }],
        "footer": { "show": false }
      },
      "title": "Trace Search",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  TraceId,\n  any(ServiceName) AS ServiceName,\n  any(SpanName) AS RootSpan,\n  min(Timestamp) AS \"Start Time\",\n  max(Duration) AS Duration,\n  count() AS SpanCount,\n  anyIf(StatusCode, StatusCode = 'STATUS_CODE_ERROR') AS Status\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($operation = '' OR SpanName = $operation)\n  AND ($status = '' OR StatusCode = $status)\n  AND ($min_duration = 0 OR Duration >= $min_duration * 1000000)\nGROUP BY TraceId\nORDER BY \"Start Time\" DESC\nLIMIT 100",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 3,
      "options": {
        "bucketSize": "",
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Duration Distribution",
      "type": "histogram",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  Duration / 1000000 AS duration_ms\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nLIMIT 10000",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "align": "auto", "filterable": true }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "id": 5,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "title": "Top Operations",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  ServiceName,\n  SpanName AS Operation,\n  count() AS Count,\n  countIf(StatusCode = 'STATUS_CODE_ERROR') AS Errors,\n  quantile(0.5)(Duration) / 1000000 AS \"P50 (ms)\",\n  quantile(0.99)(Duration) / 1000000 AS \"P99 (ms)\"\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\nGROUP BY ServiceName, SpanName\nORDER BY Count DESC\nLIMIT 50",
          "refId": "A",
          "format": 1
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "traces"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "grafana-clickhouse-datasource",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "", "value": "" },
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": false,
        "name": "service",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_traces WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY ServiceName" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "allValue": ""
      },
      {
        "current": { "selected": true, "text": "", "value": "" },
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0,
        "includeAll": true,
        "label": "Operation",
        "multi": false,
        "name": "operation",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT SpanName FROM $__database.otel_traces WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime AND ($service = '' OR ServiceName = $service) ORDER BY SpanName" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "allValue": ""
      },
      {
        "current": { "selected": true, "text": "", "value": "" },
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0,
        "includeAll": true,
        "label": "Status",
        "multi": false,
        "name": "status",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT StatusCode FROM $__database.otel_traces WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY StatusCode" },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "allValue": ""
      },
      {
        "current": { "selected": false, "text": "0", "value": "0" },
        "hide": 0,
        "label": "Min Duration (ms)",
        "name": "min_duration",
        "options": [{ "selected": true, "text": "0", "value": "0" }],
        "query": "0",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OTel Traces Explorer",
  "uid": "otel-traces-explorer",
  "version": 1
}
