{
  "annotations": { "list": [] },
  "description": "Explore OpenTelemetry traces stored in ClickHouse. Filter by service, operation, status, or duration — no SQL required.",
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["clickhouse", "otel"], "title": "OTEL Dashboards", "type": "dashboards" }
  ],
  "panels": [
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeName": "Turquoise" },
          "custom": { "scaleDistribution": { "type": "log", "log": 2 } }
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scheme": "Turquoise", "steps": 64 },
        "filterValues": { "le": 0 },
        "showValue": "never",
        "tooltip": { "show": true, "yHistogram": true },
        "yAxis": { "axisLabel": "Duration", "axisPlacement": "left", "reverse": false, "unit": "ns" }
      },
      "title": "Trace Duration Heatmap",
      "type": "heatmap",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  Duration\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($operation = '' OR SpanName = $operation)\n  AND ParentSpanId = ''\nLIMIT 50000",
        "refId": "A", "format": 1
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" }
      },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 5 },
      "id": 10,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  ServiceName,\n  count() AS count\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time, ServiceName\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 5 },
      "id": 11,
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  countIf(StatusCode = 'STATUS_CODE_ERROR') / count() AS error_rate\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }, "unit": "ns" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "id": 12,
      "title": "Duration Percentiles (p50 / p90 / p99)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  quantile(0.5)(Duration) AS p50,\n  quantile(0.9)(Duration) AS p90,\n  quantile(0.99)(Duration) AS p99\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true, "cellOptions": { "type": "auto" } },
          "links": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Duration" }, "properties": [{ "id": "unit", "value": "ns" }, { "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Spans" }, "properties": [{ "id": "custom.width", "value": 70 }] },
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [
            { "id": "custom.width", "value": 100 },
            { "id": "mappings", "value": [
              { "type": "value", "options": { "STATUS_CODE_ERROR": { "text": "Error", "color": "red" }, "STATUS_CODE_OK": { "text": "OK", "color": "green" }, "STATUS_CODE_UNSET": { "text": "Unset", "color": "text" } } }
            ]}
          ]},
          { "matcher": { "id": "byName", "options": "TraceId" }, "properties": [{ "id": "custom.width", "value": 280 }] },
          { "matcher": { "id": "byName", "options": "Service" }, "properties": [{ "id": "custom.width", "value": 160 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "id": 20,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }],
        "footer": { "show": true, "countRows": true, "reducer": ["count"] }
      },
      "title": "Trace Search Results",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  TraceId,\n  any(ServiceName) AS Service,\n  any(SpanName) AS RootOperation,\n  min(Timestamp) AS Time,\n  max(Duration) AS Duration,\n  count() AS Spans,\n  anyIf(StatusCode, StatusCode = 'STATUS_CODE_ERROR') AS Status\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($operation = '' OR SpanName = $operation)\n  AND ($status = '' OR StatusCode = $status)\n  AND ($min_duration = 0 OR Duration >= toUInt64($min_duration) * 1000000)\nGROUP BY TraceId\nORDER BY Time DESC\nLIMIT 200",
        "refId": "A", "format": 1
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "unit", "value": "ns" }] },
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "unit", "value": "ns" }] }
        ]
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 22 },
      "id": 30,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Count" }] },
      "title": "Top Operations (by throughput)",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  ServiceName AS Service,\n  SpanName AS Operation,\n  count() AS Count,\n  countIf(StatusCode = 'STATUS_CODE_ERROR') AS Errors,\n  round(countIf(StatusCode = 'STATUS_CODE_ERROR') / count() * 100, 2) AS \"Error %\",\n  quantile(0.5)(Duration) AS P50,\n  quantile(0.99)(Duration) AS P99\nFROM $__database.otel_traces\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\nGROUP BY Service, Operation\nORDER BY Count DESC\nLIMIT 50",
        "refId": "A", "format": 1
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "traces"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "label": "Data Source", "name": "datasource", "query": "grafana-clickhouse-datasource", "refresh": 1, "type": "datasource" },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_traces WHERE $__timeFilter(Timestamp) ORDER BY ServiceName" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Operation", "multi": false, "name": "operation",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT SpanName FROM $__database.otel_traces WHERE $__timeFilter(Timestamp) AND ($service = '' OR ServiceName = $service) ORDER BY SpanName LIMIT 200" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Status", "multi": false, "name": "status",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT StatusCode FROM $__database.otel_traces WHERE $__timeFilter(Timestamp) ORDER BY StatusCode" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "current": { "selected": false, "text": "0", "value": "0" },
        "hide": 0, "label": "Min Duration (ms)", "name": "min_duration",
        "options": [{ "selected": true, "text": "0", "value": "0" }],
        "query": "0", "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OTel Traces Explorer",
  "uid": "otel-traces-explorer",
  "version": 1
}
