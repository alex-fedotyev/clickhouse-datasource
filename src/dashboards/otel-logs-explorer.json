{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["clickhouse", "otel"],
      "title": "ClickHouse OTEL Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "barAlignment": 0,
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warn" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "debug" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "trace" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "fatal" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Log Volume by Level",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  SUM(multiSearchAny(toString(SeverityText), ['ERROR', 'error', 'Error', 'ERR', 'FATAL', 'fatal', 'Fatal'])) AS error,\n  SUM(multiSearchAny(toString(SeverityText), ['WARN', 'warn', 'Warn', 'WARNING', 'warning'])) AS warn,\n  SUM(multiSearchAny(toString(SeverityText), ['INFO', 'info', 'Info', 'INFORMATION'])) AS info,\n  SUM(multiSearchAny(toString(SeverityText), ['DEBUG', 'debug', 'Debug', 'DBUG'])) AS debug,\n  SUM(multiSearchAny(toString(SeverityText), ['TRACE', 'trace', 'Trace'])) AS trace\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level = '' OR SeverityText = $level)\n  AND ($search = '' OR hasToken(Body, $search))\nGROUP BY time\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barAlignment": 0
          }
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Logs by Service",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  ServiceName,\n  count() AS count\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level = '' OR SeverityText = $level)\n  AND ($search = '' OR hasToken(Body, $search))\nGROUP BY time, ServiceName\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  countIf(SeverityText IN ('ERROR', 'error', 'Error', 'FATAL', 'fatal', 'Fatal')) / count() AS error_rate\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($search = '' OR hasToken(Body, $search))\nGROUP BY time\nORDER BY time",
          "refId": "A",
          "format": 0
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {}
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 12 },
      "id": 4,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "title": "Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "editorType": "sql",
          "rawSql": "SELECT\n  Timestamp AS timestamp,\n  Body AS body,\n  SeverityText AS level,\n  ServiceName,\n  TraceId,\n  SpanId,\n  mapKeys(ResourceAttributes) AS resource_keys,\n  mapValues(ResourceAttributes) AS resource_values,\n  mapKeys(LogAttributes) AS log_attr_keys,\n  mapValues(LogAttributes) AS log_attr_values\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level = '' OR SeverityText = $level)\n  AND ($search = '' OR hasToken(Body, $search))\nORDER BY Timestamp DESC\nLIMIT 500",
          "refId": "A",
          "format": 2
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "grafana-clickhouse-datasource",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "", "value": "" },
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "definition": "SELECT DISTINCT ServiceName FROM $__database.otel_logs WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY ServiceName",
        "hide": 0,
