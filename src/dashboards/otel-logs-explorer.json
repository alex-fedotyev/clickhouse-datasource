{
  "annotations": { "list": [] },
  "description": "Explore OpenTelemetry logs stored in ClickHouse. Filter by service, level, or any attribute — no SQL required.",
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["clickhouse", "otel"], "title": "OTEL Dashboards", "type": "dashboards" }
  ],
  "panels": [
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeName": "Oranges" },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "scaleDistribution": { "type": "log", "log": 2 }
          }
        }
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scheme": "Oranges", "steps": 64 },
        "filterValues": { "le": 0 },
        "showValue": "never",
        "tooltip": { "show": true, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false }
      },
      "title": "Log Volume",
      "type": "heatmap",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  SeverityText AS level,\n  count() AS count\nFROM $__database.otel_logs\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level_filter = '' OR SeverityText = $level_filter)\n  AND ($search = '' OR hasToken(Body, $search))\n  $__conditionalAll(AND ServiceName IN ($service), $service)\nGROUP BY time, level\nORDER BY time, level",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": { "mode": "normal" }, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "TRACE" }, "properties": [{ "id": "color", "value": { "fixedColor": "#B877D9", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FATAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "#C4162A", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 16, "x": 0, "y": 4 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Volume by Level",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  SeverityText AS metric,\n  count() AS count\nFROM $__database.otel_logs\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level_filter = '' OR SeverityText = $level_filter)\n  AND ($search = '' OR hasToken(Body, $search))\nGROUP BY time, metric\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "align": "auto" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 4 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Services",
      "type": "bargauge",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  ServiceName AS Service,\n  count() AS Count\nFROM $__database.otel_logs\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level_filter = '' OR SeverityText = $level_filter)\n  AND ($search = '' OR hasToken(Body, $search))\nGROUP BY Service\nORDER BY Count DESC\nLIMIT 15",
        "refId": "A", "format": 1
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "title": "Logs",
      "type": "logs",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  Timestamp AS timestamp,\n  Body AS body,\n  SeverityText AS level,\n  ServiceName,\n  TraceId,\n  SpanId,\n  ResourceAttributes['service.namespace'] AS namespace,\n  ResourceAttributes['k8s.namespace.name'] AS k8s_namespace,\n  ResourceAttributes['k8s.pod.name'] AS k8s_pod,\n  ResourceAttributes['k8s.container.name'] AS k8s_container,\n  ResourceAttributes['k8s.deployment.name'] AS k8s_deployment\nFROM $__database.otel_logs\nWHERE $__timeFilter(Timestamp)\n  AND ($service = '' OR ServiceName = $service)\n  AND ($level_filter = '' OR SeverityText = $level_filter)\n  AND ($search = '' OR hasToken(Body, $search))\nORDER BY Timestamp DESC\nLIMIT 500",
        "refId": "A", "format": 2
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "logs"],
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "label": "Data Source", "name": "datasource",
        "query": "grafana-clickhouse-datasource", "refresh": 1, "type": "datasource"
      },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_logs WHERE $__timeFilter(Timestamp) ORDER BY ServiceName" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Level", "multi": true, "name": "level_filter",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT SeverityText FROM $__database.otel_logs WHERE $__timeFilter(Timestamp) ORDER BY SeverityText" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0, "label": "Search", "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "", "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OTel Logs Explorer",
  "uid": "otel-logs-explorer",
  "version": 1
}
