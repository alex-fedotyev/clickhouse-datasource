        "multi": false,
        "name": "service",
        "options": [],
        "query": {
          "editorType": "sql",
          "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_logs WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY ServiceName"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query",
        "allValue": ""
      },
      {
        "current": { "selected": true, "text": "", "value": "" },
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "definition": "SELECT DISTINCT SeverityText FROM $__database.otel_logs WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY SeverityText",
        "hide": 0,
        "includeAll": true,
        "label": "Level",
        "multi": false,
        "name": "level",
        "options": [],
        "query": {
          "editorType": "sql",
          "rawSql": "SELECT DISTINCT SeverityText FROM $__database.otel_logs WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY SeverityText"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query",
        "allValue": ""
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OTel Logs Explorer",
  "uid": "otel-logs-explorer",
  "version": 1
}
