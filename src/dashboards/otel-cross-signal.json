{
  "__inputs": [
    { "name": "DS_CLICKHOUSE", "label": "ClickHouse", "type": "datasource", "pluginId": "grafana-clickhouse-datasource" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["clickhouse", "otel"], "title": "ClickHouse OTEL Dashboards", "type": "dashboards" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Metrics & Traces",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error_rate" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "percentunit" }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "title": "Request Rate + Error Rate",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  count() / $__interval_s AS request_rate,\n  countIf(StatusCode = 'STATUS_CODE_ERROR') / count() AS error_rate\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ParentSpanId = ''\nGROUP BY time\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time,\n  SeverityText AS level,\n  count() AS count\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\nGROUP BY time, level\nORDER BY time",
        "refId": "A", "format": 0
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Duration" }, "properties": [{ "id": "unit", "value": "ns" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Recent Traces",
      "type": "table",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  TraceId,\n  any(ServiceName) AS Service,\n  any(SpanName) AS RootSpan,\n  min(Timestamp) AS Time,\n  max(Duration) AS Duration,\n  count() AS Spans,\n  anyIf(StatusCode, StatusCode = 'STATUS_CODE_ERROR') AS Status\nFROM $__database.otel_traces\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\nGROUP BY TraceId\nORDER BY Time DESC\nLIMIT 50",
        "refId": "A", "format": 1
      }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "title": "Logs",
      "type": "logs",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "sql",
        "rawSql": "SELECT\n  Timestamp AS timestamp,\n  Body AS body,\n  SeverityText AS level,\n  ServiceName,\n  TraceId,\n  SpanId\nFROM $__database.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND ($service = '' OR ServiceName = $service)\n  AND ($traceId = '' OR TraceId = $traceId)\nORDER BY Timestamp DESC\nLIMIT 200",
        "refId": "A", "format": 2
      }]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 101,
      "title": "Trace Detail (set $traceId above or click a TraceId)",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 17 },
          "id": 5,
          "title": "Trace Waterfall",
          "type": "traces",
          "targets": [{
            "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
            "editorType": "sql",
            "rawSql": "SELECT\n  TraceId AS traceID,\n  SpanId AS spanID,\n  ParentSpanId AS parentSpanID,\n  ServiceName AS serviceName,\n  SpanName AS operationName,\n  Timestamp AS startTime,\n  Duration / 1000000 AS duration,\n  StatusCode AS statusCode,\n  StatusMessage AS statusMessage,\n  SpanKind,\n  SpanAttributes,\n  ResourceAttributes\nFROM $__database.otel_traces\nWHERE TraceId = $traceId\n  AND $traceId != ''\nORDER BY Timestamp",
            "refId": "A", "format": 3
          }]
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "correlation"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "label": "Data Source", "name": "datasource", "query": "grafana-clickhouse-datasource", "refresh": 1, "type": "datasource" },
      {
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "hide": 0, "includeAll": true, "label": "Service", "name": "service",
        "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_traces WHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime ORDER BY ServiceName" },
        "refresh": 2, "sort": 1, "type": "query", "allValue": ""
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0, "label": "Trace ID", "name": "traceId",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "", "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Cross-Signal Correlation",
  "uid": "otel-cross-signal",
  "version": 1
}
