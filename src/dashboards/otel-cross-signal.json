{
  "description": "Cross-signal correlation. Click a TraceId in Traces or Logs Explorer to land here and see the full picture — trace waterfall, correlated logs, and metrics.",
  "editable": true,
  "graphTooltip": 2,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["clickhouse", "otel"], "title": "OTEL Dashboards", "type": "dashboards" }
  ],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Context: ${service}", "type": "row" },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" },
        "overrides": [{ "matcher": { "id": "byName", "options": "error_rate" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "percentunit" }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 1 }, "id": 1,
      "title": "Request Rate + Error Rate", "type": "timeseries",
      "targets": [{ "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" }, "editorType": "sql", "rawSql": "SELECT toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time, count() / $__interval_s AS request_rate, countIf(StatusCode = 'STATUS_CODE_ERROR') / count() AS error_rate FROM $__database.otel_traces WHERE $__timeFilter(Timestamp) AND ($service = '' OR ServiceName IN ($service)) AND ParentSpanId = '' GROUP BY time ORDER BY time", "refId": "A", "format": 0 }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" }, "lineWidth": 0, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 }, "id": 2,
      "title": "Log Volume by Level", "type": "timeseries",
      "targets": [{ "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" }, "editorType": "sql", "rawSql": "SELECT toStartOfInterval(Timestamp, INTERVAL $__interval_s second) AS time, SeverityText AS metric, count() AS count FROM $__database.otel_logs WHERE $__timeFilter(Timestamp) AND ($service = '' OR ServiceName IN ($service)) GROUP BY time, metric ORDER BY time", "refId": "A", "format": 0 }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }, "id": 101, "title": "Trace: ${traceId}", "type": "row" },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Duration" }, "properties": [{ "id": "unit", "value": "ns" }] },
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "STATUS_CODE_ERROR": { "text": "Error", "color": "red" }, "STATUS_CODE_OK": { "text": "OK", "color": "green" }, "STATUS_CODE_UNSET": { "text": "—" }, "": { "text": "OK", "color": "green" } } }] }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }] }
        ]
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 8 }, "id": 3,
      "options": { "showHeader": true },
      "title": "Trace Summary", "type": "table",
      "targets": [{ "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" }, "editorType": "sql", "rawSql": "SELECT TraceId, ServiceName AS Service, SpanName AS Operation, Timestamp AS Time, Duration, StatusCode AS Status, SpanKind FROM $__database.otel_traces WHERE TraceId = $traceId AND $traceId != '' ORDER BY Timestamp LIMIT 100", "refId": "A", "format": 1 }]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 }, "id": 4,
      "title": "Trace Waterfall", "type": "traces",
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
        "editorType": "builder",
        "builderOptions": {
          "database": "otel_v2", "table": "otel_traces",
          "queryType": "traces",
          "columns": [
            { "name": "Timestamp", "hint": "time" },
            { "name": "TraceId", "hint": "trace_id" },
            { "name": "SpanId", "hint": "trace_span_id" },
            { "name": "ParentSpanId", "hint": "trace_parent_span_id" },
            { "name": "ServiceName", "hint": "trace_service_name" },
            { "name": "SpanName", "hint": "trace_operation_name" },
            { "name": "Duration", "hint": "trace_duration_time" },
            { "name": "SpanAttributes", "hint": "trace_tags" },
            { "name": "ResourceAttributes", "hint": "trace_service_tags" },
            { "name": "StatusCode", "hint": "trace_status_code" },
            { "name": "StatusMessage", "hint": "trace_status_message" },
            { "name": "SpanKind", "hint": "trace_kind" }
          ],
          "filters": [],
          "meta": {
            "isTraceIdMode": true,
            "traceId": "${traceId}",
            "traceDurationUnit": "nanoseconds",
            "otelEnabled": true,
            "otelVersion": "latest"
          }
        },
        "rawSql": "",
        "refId": "A", "format": 3
      }]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }, "id": 102, "title": "Correlated Logs", "type": "row" },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 }, "id": 5,
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Ascending" },
      "title": "Logs for trace ${traceId}", "type": "logs",
      "targets": [{ "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" }, "editorType": "sql", "rawSql": "SELECT Timestamp AS timestamp, Body AS body, SeverityText AS level, ServiceName, TraceId, SpanId FROM $__database.otel_logs WHERE $__timeFilter(Timestamp) AND ($traceId = '' OR TraceId = $traceId) AND ($service = '' OR ServiceName IN ($service)) ORDER BY Timestamp ASC LIMIT 500", "refId": "A", "format": 2 }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["clickhouse", "otel", "correlation"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "label": "Data Source", "name": "datasource", "query": "grafana-clickhouse-datasource", "refresh": 1, "type": "datasource" },
      { "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${datasource}" }, "hide": 0, "includeAll": true, "label": "Service", "multi": true, "name": "service", "query": { "editorType": "sql", "rawSql": "SELECT DISTINCT ServiceName FROM $__database.otel_traces WHERE $__timeFilter(Timestamp) ORDER BY ServiceName" }, "refresh": 2, "sort": 1, "type": "query", "allValue": "" },
      { "current": { "selected": false, "text": "", "value": "" }, "hide": 0, "label": "Trace ID", "name": "traceId", "options": [{ "selected": true, "text": "", "value": "" }], "query": "", "type": "textbox" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "", "title": "Cross-Signal Correlation", "uid": "otel-cross-signal", "version": 1
}
